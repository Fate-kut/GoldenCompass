{
  "expo": {
    "name": "Golden Compass",
    "slug": "golden-compass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0E1A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.goldencompass.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.goldencompass.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "golden-compass",
    "experiments": {
      "typedRoutes": true
    }
  }
}
